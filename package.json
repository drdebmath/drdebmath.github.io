{
  "name": "drdebmath-github-io",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:seo",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/tailwind.css -o ./assets/site.css --minify",
    "build:seo": "node gen-seo.mjs",
    "validate": "npm run build:css && node validate-site.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
